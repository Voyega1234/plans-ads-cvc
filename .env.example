# ─────────────────────────────────────────────────────────────────────────────
# Plans Ads — Environment Variables Template
# คัดลอกไฟล์นี้เป็น .env.local แล้วเติมค่าจริงทุกตัว
# ─────────────────────────────────────────────────────────────────────────────

# ── App ───────────────────────────────────────────────────────────────────────
# Local:      http://localhost:3010
# Production: https://your-app.vercel.app
NEXTAUTH_URL=http://localhost:3010
NEXTAUTH_SECRET=                          # สร้างด้วย: openssl rand -base64 32

# ── Database (Supabase Postgres) ───────────────────────────────────────────────
# หาได้ที่: Supabase Dashboard → Project Settings → Database → Connection string
# DATABASE_URL = Connection pooling (Transaction mode, port 6543) ใช้ตอน runtime
# DIRECT_URL   = Direct connection (port 5432) ใช้ตอน migrate / db push
# NOTE: ?schema=plans_ads แยก table ของแอปนี้ออกจาก schema public (ที่มีแอป SEO อยู่)
DATABASE_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&schema=plans_ads"
DIRECT_URL="postgresql://postgres.<ref>:<password>@<region>.pooler.supabase.com:5432/postgres?schema=plans_ads"

# ── Google OAuth — ใช้สำหรับ Login ──────────────────────────────────────────
# สร้างที่: console.cloud.google.com → APIs & Services → Credentials
# ต้องเพิ่ม Authorized redirect URIs: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── AI Providers ──────────────────────────────────────────────────────────────
# Gemini (primary — ใช้ gemini-3.5-flash เสมอ ห้าม downgrade)
GEMINI_API_KEY=
AI_MODEL_QUALITY=gemini-3.5-flash
AI_MODEL_STANDARD=gemini-3.5-flash
MOCK_AI=false

# Anthropic (backup)
ANTHROPIC_API_KEY=

# OpenAI (optional)
OPENAI_API_KEY=

# ── Google Ads API ────────────────────────────────────────────────────────────
MOCK_GOOGLE_ADS=false
AUTOMATION_MUTATE=false                   # true = ปิด safety lock (production เท่านั้น)

GOOGLE_ADS_DEVELOPER_TOKEN=               # Google Ads Manager → Tools → API Center
GOOGLE_ADS_CLIENT_ID=                     # ใช้ Client ID เดียวกับ Google OAuth ได้
GOOGLE_ADS_CLIENT_SECRET=                 # ใช้ Client Secret เดียวกับ Google OAuth
GOOGLE_ADS_REFRESH_TOKEN=                 # สร้างด้วย OAuth Playground (ดู DEPLOY_GUIDE.md ข้อ 3)
GOOGLE_ADS_LOGIN_CUSTOMER_ID=             # MCC account ID ไม่มี dash เช่น 6140243864
GOOGLE_ADS_CUSTOMER_ID=                   # Sub-account IDs คั่นด้วย comma เช่น 1234567890,9876543210
COMPANY_MCC_CUSTOMER_ID=                  # ค่าเดียวกับ GOOGLE_ADS_LOGIN_CUSTOMER_ID

# ── GA4 ───────────────────────────────────────────────────────────────────────
# ใช้ OAuth token ของ user ที่ login — ต้องมี Viewer access ใน GA4 property
GA4_PROPERTY_ID=                          # เช่น 540948580 (GA4 Admin → Property Settings)

# ── Google Tag Manager ────────────────────────────────────────────────────────
GTM_ACCOUNT_ID=
GTM_CONTAINER_ID=
GTM_SERVICE_ACCOUNT_EMAIL=               # Service Account ที่มี GTM Read access
GTM_SERVICE_ACCOUNT_PRIVATE_KEY=         # JSON key → private_key (ต้องใช้ \n แทน newline จริง)

# ── Google Sheets / Drive ─────────────────────────────────────────────────────
GOOGLE_SHEETS_ENABLED=true
GOOGLE_DRIVE_ENABLED=true
GOOGLE_SHEETS_CLIENT_EMAIL=              # Service Account email
GOOGLE_SHEETS_PRIVATE_KEY=              # Service Account private key (ต้องใช้ \n)
GOOGLE_DRIVE_FOLDER_ID=                 # Google Drive folder ID สำหรับ export reports

# ── Dev only — ห้ามเปิดบน Production ────────────────────────────────────────
# SKIP_AUTH=true
